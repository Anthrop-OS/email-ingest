# ==============================================================================
# Email Ingest Service - Environment Variables Template
# ------------------------------------------------------------------------------
# INSTRUCTIONS:
# 1. Copy this file and rename it to `.env`.
# 2. Fill in the actual secret values.
# 3. DO NOT commit the `.env` file to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. EMAIL ACCOUNT SECRETS
# ------------------------------------------------------------------------------
# These variables map to the `password_env_var` field in your `config.yaml`.
# You can define multiple environment variables here if aggregating multiple inboxes.

# (Example) Mapped from config.yaml -> email_accounts[0] -> password_env_var: "WORK_EMAIL_PASSWORD"
WORK_EMAIL_PASSWORD="your_company_email_app_password"

# (Example) Mapped from config.yaml -> email_accounts[1] -> password_env_var: "PERSONAL_EMAIL_PASSWORD"
# PERSONAL_EMAIL_PASSWORD="your_personal_email_app_password"


# ------------------------------------------------------------------------------
# 2. AI / LLM SECRETS
# ------------------------------------------------------------------------------
# The API key for your chosen LLM Provider (OpenAI, Gemini, Claude).
LLM_API_KEY="sk-your-llm-api-key"

# (Optional) OpenRouter API key. Used when provider_type = "openrouter" in config.yaml.
# Get yours at https://openrouter.ai/keys — keys start with "sk-or-"
# OPENROUTER_API_KEY="sk-or-your-openrouter-key"

# (Optional) Base URL overrides. 
# Extremely useful if using local inference like vLLM, Ollama, or an API Proxy.
# Not needed for OpenRouter (auto-set to https://openrouter.ai/api/v1).
# LLM_BASE_URL="http://localhost:8000/v1"


# ------------------------------------------------------------------------------
# 3. OUTPUT CHANNEL / OPENCLAW SECRETS (Provided for Interface Usage)
# ------------------------------------------------------------------------------
# These will be utilized if you implement the IOutputChannel for OpenClaw.
OPENCLAW_WEBHOOK_URL="https://api.openclaw.example.com/v1/ingest"
OPENCLAW_AUTH_TOKEN="oc_token_your_auth_token_here"


# ------------------------------------------------------------------------------
# 4. SYSTEM LOGGING & RUNTIME SECRETS
# ------------------------------------------------------------------------------
# Set logging verbosity: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL="INFO"
